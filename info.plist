				<key>script</key>
				<string>h="Authorization: Bearer $access_token"
cache="$alfred_workflow_cache/tasks.json"
active="$alfred_workflow_cache/active.json"
cats="$alfred_workflow_cache/categories.json"
search="$alfred_workflow_cache/search.json"
mkdir -p "$alfred_workflow_cache"
if [ ! -f "$cache" ] || [ $(($(date +%s) - $(stat -f %m "$cache" 2>/dev/null || echo 0))) -gt 60 ]; then
  curl -s -m 5 -H "$h" "https://timecrowd.net/api/v1/tasks?sort=user_usage&amp;limit=25" > "$cache"
fi
if [ ! -f "$cats" ] || [ $(($(date +%s) - $(stat -f %m "$cats" 2>/dev/null || echo 0))) -gt 300 ]; then
  curl -s -m 5 -H "$h" "https://timecrowd.net/api/v1/categories" > "$cats.tmp" &amp;&amp; mv "$cats.tmp" "$cats" &amp;
fi
curl -s -m 2 -H "$h" "https://timecrowd.net/api/v2/user" > "$active.tmp" &amp;&amp; mv "$active.tmp" "$active" &amp;
q="{query}"
if [ -n "$q" ] &amp;&amp; [ "$q" != "config" ]; then
  curl -s -m 3 -H "$h" -G --data-urlencode "title=$q" "https://timecrowd.net/api/v1/search/tasks" > "$search"
else
  echo "[]" > "$search"
fi
/usr/bin/python3 "$PWD/main.py" "{query}" "$active" "$search" &lt; "$cache"</string>
